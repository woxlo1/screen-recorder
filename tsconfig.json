{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@preload/*": ["src/preload/*"],
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    },
    // outDir keeps `tsc -b`'s emitted .js files out of src/ (Vite does the actual
    // bundling/transpilation separately; this output is only a side effect of
    // running tsc in build mode and is never consumed by anything).
    "outDir": "./.tsc-out",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "dist-electron", "release", ".tsc-out"]
}
